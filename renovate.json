{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "kubernetes": {
    "managerFilePatterns": ["/\\.ya?ml$/"]
  },
{
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/jonathanschwarzhaupt/home-blog",
        "ghcr.io/jonathanschwarzhaupt/home-blog-migrate"
      ],
      "matchFileNames": ["apps/base/home-blog/deployment.yaml"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-dev\\.(?<build>\\d+)\\.[0-9a-f]+$",
      "automerge": true,
      "automergeType": "branch"
    }
  ]
}
